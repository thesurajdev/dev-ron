# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional fallback for local tests only
# SUPABASE_ANON_KEY=your_anon_key_here

# Node Environment
NODE_ENV=development

# Server Port (optional)
PORT=3000

# Public URL used in OAuth metadata + MCP manifest.
# Example: https://your-domain.com
PUBLIC_BASE_URL=https://your-domain.com

# Optional local fallback scope for non-OAuth testing only.
# In production, tenant scope is derived from OAuth client tokens.
# DEFAULT_MCP_USER_ID=local-dev-user